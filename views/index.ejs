<%- include('partials/header.ejs') %>

<!-- HERO -->
<section class="banner">
	<div class="container">
		<div class="banner-content text-center mx-auto">
			<h1>Navigating Your<br> <em>Fertility Journey</em> in Ontario</h1>
			<p class="banner-sub">A neutral, clinic-independent guide that walks you through every stage — from your first family doctor visit to treatment options and government funding — so you can make informed decisions with confidence.</p>
			<a href="#overview" class="btn btn-star btn-lg">Start Here</a>
		</div>
	</div>
</section>

<!-- OVERVIEW -->
<section id="overview" class="section-overview">
	<div class="container">
		<p class="section-label">The Three Stages</p>
		<h2 class="section-title">What This Guide Covers</h2>
		<p class="section-intro">Most fertility resources assume you're already inside the system. This guide starts where you actually start — before you even see a doctor — and walks you through the process step by step.</p>

		<div class="row g-4 mt-2">
			<div class="col-md-4">
				<a href="<%= basePath %>/stage1" class="stage-card">
					<div class="stage-num">Stage 1</div>
					<h3>Before the Family Doctor</h3>
					<p>Understand infertility definitions in Ontario, learn which clinics are near you, and prepare for your GP visit so you don't waste the appointment.</p>
				</a>
			</div>
			<div class="col-md-4">
				<a href="<%= basePath %>/stage2" class="stage-card">
					<div class="stage-num">Stage 2</div>
					<h3>The Investigative Cycle</h3>
					<p>Know what tests to expect, why you need them, how often you'll go back, and what the possible diagnoses look like.</p>
				</a>
			</div>
			<div class="col-md-4">
				<a href="<%= basePath %>/stage3" class="stage-card">
					<div class="stage-num">Stage 3</div>
					<h3>Treatment & Funding</h3>
					<p>Learn about IUI, IVF, medication protocols, costs, and how Ontario's fertility funding program can help.</p>
				</a>
			</div>
		</div>
	</div>
</section>


<!-- ABOUT -->
<section id="about" class="section-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <p class="section-label">About This Guide</p>
                <h2 class="section-title">Why This Website Exists</h2>
                <p class="section-intro">This website is <strong>not affiliated with any fertility clinic</strong>, and the information presented here comes from a neutral standpoint. The goal is to fill the gap that exists between patients and the healthcare system — especially for newcomers to Canada who may be unfamiliar with how the Ontario fertility process works.</p>
                <p class=" small mt-3">This guide is for informational purposes only and does not replace professional medical advice. Always consult your healthcare provider for decisions about your care.</p>
            </div>
            <div class="col-md-4 text-center">
                <img src="<%= basePath %>/static/images/1.jpeg" alt="Image of the website author" class="about-photo">
            </div>
        </div>
    </div>
</section>

</main>
<%- include('partials/footer.ejs') %>
