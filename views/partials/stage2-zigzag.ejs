      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--sage">Cycle day 3</span>
          <h5 class="zz-title zz-title--sage">Screening blood work + hormone panel</h5>
          <p class="zz-desc">Around 6 vials covering immunities, hepatitis, HIV, plus FSH, LH, Estradiol, TSH, and Prolactin. All covered by OHIP.</p>
        </div>
        <div class="zz-circle zz-circle--sage">
          <img src="/fertility-v2/static/images/" alt="Blood work icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 2: Baseline Ultrasound -->
      <div class="zz-step zz-right">
        <div class="zz-content">
          <span class="zz-tag zz-tag--green">Cycle day 3</span>
          <h5 class="zz-title zz-title--green">Baseline ultrasound</h5>
          <p class="zz-desc">Full bladder required. External and internal imaging to check antral follicle count, uterine lining, and structural abnormalities. Covered by OHIP.</p>
        </div>
        <div class="zz-circle zz-circle--green">
          <img src="/fertility-v2/static/images/" alt="Ultrasound icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 3: Sono -->
      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--orange">Cycle day 5 to 11</span>
          <h5 class="zz-title zz-title--orange">Sono (Sonohysterogram)</h5>
          <p class="zz-desc">Saline injected during internal ultrasound to check for polyps, fibroids, or uterine issues. Take 2 pain relievers 1 hour before. Covered by OHIP.</p>
        </div>
        <div class="zz-circle zz-circle--orange">
          <img src="/fertility-v2/static/images/" alt="Sono icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 4: Cycle Monitoring -->
      <div class="zz-step zz-right">
        <div class="zz-content">
          <span class="zz-tag zz-tag--terra">Cycle day 10 to 18</span>
          <h5 class="zz-title zz-title--terra">Cycle monitoring</h5>
          <p class="zz-desc">Every other day for internal ultrasound and blood work. Monitoring hormones and follicle development to pinpoint ovulation. Covered by OHIP.</p>
        </div>
        <div class="zz-circle zz-circle--terra">
          <img src="/fertility-v2/static/images/" alt="Cycle monitoring icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 5: Progesterone -->
      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--navy">Around cycle day 20</span>
          <h5 class="zz-title zz-title--navy">P4 / Progesterone</h5>
          <p class="zz-desc">One vial of blood to confirm ovulation. Your nurse will confirm the exact date based on your cycle length. Covered by OHIP.</p>
        </div>
        <div class="zz-circle zz-circle--navy">
          <img src="/fertility-v2/static/images/" alt="Progesterone icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 6: Beta HCG -->
      <div class="zz-step zz-right">
        <div class="zz-content">
          <span class="zz-tag zz-tag--sage">Around cycle day 28</span>
          <h5 class="zz-title zz-title--sage">Beta HCG / Pregnancy test</h5>
          <p class="zz-desc">One vial of blood to confirm your Beta HCG level. Your nurse will confirm the exact date. Covered by OHIP.</p>
        </div>
        <div class="zz-circle zz-circle--sage">
          <img src="/fertility-v2/static/images/" alt="Beta HCG icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 7: AMH + Vitamin D -->
      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--green">Any day</span>
          <h5 class="zz-title zz-title--green">AMH + Vitamin D</h5>
          <p class="zz-desc">AMH measures ovarian reserve (~$105). Vitamin D checks levels that affect fertility (~$65). Neither covered by OHIP.</p>
        </div>
        <div class="zz-circle zz-circle--green">
          <img src="/fertility-v2/static/images/" alt="AMH and Vitamin D icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 8: Semen Analysis -->
      <div class="zz-step zz-right">
        <div class="zz-content">
          <span class="zz-tag zz-tag--orange">By appointment</span>
          <h5 class="zz-title zz-title--orange">Comprehensive semen analysis with strict morphology</h5>
          <p class="zz-desc">If you have a male partner, they will need to provide a sample. Evaluates sperm count, motility, and shape. Must abstain 3 days before. Appointment required.</p>
        </div>
        <div class="zz-circle zz-circle--orange">
          <img src="/fertility-v2/static/images/" alt="Semen analysis icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 9: Review Appointment -->
      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--terra">After day 21</span>
          <h5 class="zz-title zz-title--terra">Review appointment</h5>
          <p class="zz-desc">Your doctor reviews all results, determines your type of infertility, and creates a treatment plan. Can be done online or in person.</p>
        </div>
        <div class="zz-circle zz-circle--terra">
          <img src="/fertility-v2/static/images/" alt="Review appointment icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

    </div>
  </div>
</section>

