<style>
  /* ---- Group label ---- */
  .test-grid_group-label {
    font-size: 1.5rem;
    color: var(--sage-dark);
    letter-spacing: 0.05em;
    margin: 2.5rem 0 1.25rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--terracotta-light);
  }

  .test-grid_group-label:first-child {
    margin-top: 0;
  }

  /* ---- Grid layout ---- */
  .test-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  /* Single card row (for male partner section) */
.test-grid--two {
    grid-template-columns: repeat(2, 1fr);
    max-width: 660px;
    margin-left: auto;
    margin-right: auto;
}

  /* ---- Card ---- */
  .test-card {
    background: #fff;
    border: 1px solid var(--terracotta-light);
    border-radius: 12px;
    padding: 1.5rem 1.2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    height: 100%;
    min-height: 280px;
  }

  .test-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 16px rgba(0,0,0,0.08);
  }

  /* ---- Circle ---- */
  .test-card_circle {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 3px solid;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .test-card_circle img {
    width: 60px;
    height: 60px;
    object-fit: contain;
  }

  .test-card_circle--sage   { border-color: var(--sage); }
  .test-card_circle--green  { border-color: var(--green-title); }
  .test-card_circle--orange { border-color: var(--orange-red); }
  .test-card_circle--terra  { border-color: var(--terracotta); }
  .test-card_circle--navy   { border-color: var(--navy-dark); }

  /* ---- Content ---- */
  .test-card__content {
    width: 100%;
    flex: 1;               
    display: flex;
    flex-direction: column;
  }

  /* ---- Tag ---- */
  .test-card_tag {
    display: inline-block;
    font-size: 1rem;
    padding: 2px 10px;
    border-radius: 10px;
    margin-bottom: 0.4rem;
    font-weight: 600;
  }

  .test-card_tag--sage   { background: rgba(139,168,136,0.15); color: var(--sage); }
  .test-card_tag--green  { background: rgba(48,150,38,0.15);   color: var(--green-title); }
  .test-card_tag--orange { background: rgba(223,116,74,0.15);  color: var(--orange-red); }
  .test-card_tag--terra  { background: rgba(196,129,106,0.15); color: var(--terracotta); }
  .test-card_tag--navy   { background: rgba(21,68,122,0.15);   color: var(--navy-dark); }

  .test-card_tag--optional {
    background: rgba(120,120,120,0.12);
    color: #666;
    border: 1px dashed #999;
  }

  /* ---- Title ---- */
  .test-card_title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .test-card_title--sage   { color: var(--sage); }
  .test-card_title--green  { color: var(--green-title); }
  .test-card_title--orange { color: var(--orange-red); }
  .test-card_title--terra  { color: var(--terracotta); }
  .test-card_title--navy   { color: var(--navy-dark); }

  /* ---- Description ---- */
  .test-card_desc {
    font-size: 0.82rem;
    color: var(--charcoal);
    line-height: 1.5;
    margin-bottom: 0;
    margin-top: auto;
  }

  /* ---- For a tag ---- */
  .test-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
}

.timeline-item {
    scroll-margin-top: 80px;
}

.test-card-link:hover {
    text-decoration: none;
}

html {
    scroll-behavior: smooth;
}


  /* ---- Responsive ---- */
  @media (max-width: 991px) {
    .test-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 575px) {
    .test-grid {
      grid-template-columns: 1fr;
      max-width: 320px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>