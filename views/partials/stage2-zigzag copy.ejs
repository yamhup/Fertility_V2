<!-- Investigative Cycle: Zigzag Timeline -->
<section class="zigzag-timeline py-5">
  <div class="container">
    <div class="zz">
      <div class="zz-line"></div>

      <!-- Step 1: Screening Blood Work -->
      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--sage">Cycle day 3</span>
          <h5 class="zz-title zz-title--sage">Screening blood work + hormone panel</h5>
          <p class="zz-desc">
          6 vials in one visit. FSH, LH, and Estradiol must be done on Day 3, so your clinic will draw 
          all other baseline screening at the same time, including thyroid function, hormones, and required 
          infectious disease and immunity screening.
          <br>All covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP 
				(Ontario Health Insurance Plan) is Ontario's publicly funded health insurance, available to eligible Ontario 
				residents at no cost.">OHIP</span> .

          </p>
        </div>
        <div class="zz-circle zz-circle--sage">
          <img src="<%= basePath %>/static/images/" alt="Blood work icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 2: Baseline Ultrasound -->
      <div class="zz-step zz-right">
        <div class="zz-content">
          <span class="zz-tag zz-tag--green">Cycle day 3</span>
          <h5 class="zz-title zz-title--green">Baseline ultrasound</h5>
          <p class="zz-desc">Full bladder required. External and internal imaging to check antral follicle count, uterine 
            lining, and structural abnormalities.<Br>
            Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP 
            (Ontario Health Insurance Plan) is Ontario's publicly funded health insurance, available to eligible Ontario 
            residents at no cost.">OHIP</span> .
          </p>
        </div>
        <div class="zz-circle zz-circle--green">
          <img src="<%= basePath %>/static/images/" alt="Ultrasound icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 3: Sono -->
      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--orange">Cycle day 5 to 11</span>
          <h5 class="zz-title zz-title--orange">Sono (Sonohysterogram)</h5>
          <p class="zz-desc">Saline injected during internal ultrasound to check for polyps, fibroids, or uterine issues. Take 2 
            Advil or Tylenol 1 hour before.<br>
            Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP 
            (Ontario Health Insurance Plan) is Ontario's publicly funded health insurance, available to eligible Ontario 
            residents at no cost.">OHIP</span> .
          </p>
        </div>
        <div class="zz-circle zz-circle--orange">
          <img src="<%= basePath %>/static/images/" alt="Sono icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 4: Cycle Monitoring -->
      <div class="zz-step zz-right">
        <div class="zz-content">
          <span class="zz-tag zz-tag--terra">Cycle day 10 to 18</span>
          <h5 class="zz-title zz-title--terra">Cycle monitoring</h5>
          <p class="zz-desc">Every other day for internal ultrasound and blood work. Monitoring hormones and follicle development 
            to pinpoint ovulation.<Br>
            Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP 
          (Ontario Health Insurance Plan) is Ontario's publicly funded health insurance, available to eligible Ontario 
          residents at no cost.">OHIP</span>.
      </p>
        </div>
        <div class="zz-circle zz-circle--terra">
          <img src="<%= basePath %>/static/images/" alt="Cycle monitoring icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 5: Progesterone -->
      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--navy">Around cycle day 20</span>
          <h5 class="zz-title zz-title--navy">P4 / Progesterone</h5>
          <p class="zz-desc">One vial of blood to confirm ovulation. Your nurse will confirm the exact date based on your cycle 
            length.<br>
            Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP 
            (Ontario Health Insurance Plan) is Ontario's publicly funded health insurance, available to eligible Ontario 
            residents at no cost.">OHIP</span>.
          </p>
        </div>
        <div class="zz-circle zz-circle--navy">
          <img src="<%= basePath %>/static/images/" alt="Progesterone icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 6: Beta HCG -->
      <div class="zz-step zz-right">
        <div class="zz-content">
          <span class="zz-tag zz-tag--sage">Around cycle day 28</span>
          <span class="zz-tag zz-tag--optional">Optional</span>
          <h5 class="zz-title zz-title--sage">Beta HCG / Pregnancy test</h5>
          <p class="zz-desc">Only scheduled if you've told your doctor you'd like to try conceiving naturally during the investigative 
            cycle. One vial of blood to check whether the cycle resulted in pregnancy. Your nurse will confirm the exact date.<br> 
            Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP 
            (Ontario Health Insurance Plan) is Ontario's publicly funded health insurance, available to eligible Ontario 
            residents at no cost.">OHIP</span> .
          </p>
        </div>
        <div class="zz-circle zz-circle--sage">
          <img src="<%= basePath %>/static/images/" alt="Beta HCG icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 7: AMH + Vitamin D -->
      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--green">Any day</span>
          <h5 class="zz-title zz-title--green">AMH + Vitamin D</h5>
          <p class="zz-desc">AMH measures ovarian reserve. Vitamin D checks levels that may affect fertility.<br>
            Neither covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP 
            (Ontario Health Insurance Plan) is Ontario's publicly funded health insurance, available to eligible Ontario 
            residents at no cost.">OHIP</span><br>
            Expect to pay around $105 for AMH and $75 for Vitamin D.
        </p>
        </div>
        <div class="zz-circle zz-circle--green">
          <img src="<%= basePath %>/static/images/" alt="AMH and Vitamin D icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 8: Semen Analysis -->
      <div class="zz-step zz-right">
        <div class="zz-content">
          <span class="zz-tag zz-tag--orange">By appointment</span>
          <h5 class="zz-title zz-title--orange">Semen analysis</h5>
          <p class="zz-desc">If you have a male partner, they will need to provide a sample. The test evaluates sperm count, 
            motility, and shape. Your partner will be asked to abstain from ejaculation for a few days before (your clinic 
            will confirm the exact duration). Appointment required.
            <br> Not cover by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP 
            (Ontario Health Insurance Plan) is Ontario's publicly funded health insurance, available to eligible Ontario 
            residents at no cost.">OHIP</span>.
             Expect to pay around $160.
          </p>

        </div>
        <div class="zz-circle zz-circle--orange">
          <img src="<%= basePath %>/static/images/" alt="Semen analysis icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

      <!-- Step 9: Review Appointment -->
      <div class="zz-step zz-left">
        <div class="zz-content">
          <span class="zz-tag zz-tag--terra">After day 21</span>
          <h5 class="zz-title zz-title--terra">Review appointment</h5>
          <p class="zz-desc">Your doctor reviews all results, determines your type of infertility, and creates a treatment plan. 
            Can be done online or in person.
            <br>Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP 
          (Ontario Health Insurance Plan) is Ontario's publicly funded health insurance, available to eligible Ontario 
          residents at no cost.">OHIP</span> .
          </p>
        </div>
        <div class="zz-circle zz-circle--terra">
          <img src="<%= basePath %>/static/images/" alt="Review appointment icon">
        </div>
        <div class="zz-spacer"></div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ---- Zigzag container ---- */
  .zz {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .zz-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--terracotta-light);
    transform: translateX(-50%);
  }

  /* ---- Step row ---- */
  .zz-step {
    display: flex;
    align-items: center;
    margin-bottom: 2.5rem;
    position: relative;
  }

  .zz-step:last-child {
    margin-bottom: 0;
  }

  .zz-left {
    flex-direction: row;
  }

  .zz-right {
    flex-direction: row-reverse;
  }

  /* ---- Content card ---- */
  .zz-content {
    flex: 1;
    padding: 1.2rem 1.5rem;
    border-radius: 12px;
    background: #fff;
    border: 1px solid var(--terracotta-light);
  }

  .zz-left .zz-content {
    margin-right: 2rem;
    text-align: left;
  }

  .zz-right .zz-content {
    margin-left: 2rem;
    text-align: left;
  }

  .zz-spacer {
    flex: 1;
  }

  /* ---- Circle ---- */
  .zz-circle {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    overflow: hidden;
    border: 3px solid;
    background: #fff;
  }

  .zz-circle img {
    width: 60px;
    height: 60px;
    object-fit: contain;
  }

  .zz-circle--sage   { border-color: var(--sage); }
  .zz-circle--green  { border-color: var(--green-title); }
  .zz-circle--orange { border-color: var(--orange-red); }
  .zz-circle--terra  { border-color: var(--terracotta); }
  .zz-circle--navy   { border-color: var(--navy-dark); }

  /* ---- Tag / pill ---- */
  .zz-tag {
    display: inline-block;
    font-size: 0.75rem;
    padding: 2px 10px;
    border-radius: 10px;
    margin-bottom: 0.4rem;
    font-weight: 600;
  }

  .zz-tag--sage   { background: rgba(139,168,136,0.15); color: var(--sage); }
  .zz-tag--green  { background: rgba(48,150,38,0.15);   color: var(--green-title); }
  .zz-tag--orange { background: rgba(223,116,74,0.15);  color: var(--orange-red); }
  .zz-tag--terra  { background: rgba(196,129,106,0.15); color: var(--terracotta); }
  .zz-tag--navy   { background: rgba(21,68,122,0.15);   color: var(--navy-dark); }

  .zz-tag--optional { 
    background: rgba(120,120,120,0.12); 
    color: #666;
    border: 1px dashed #999;
  }

  /* ---- Title ---- */
  .zz-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .zz-title--sage   { color: var(--sage); }
  .zz-title--green  { color: var(--green-title); }
  .zz-title--orange { color: var(--orange-red); }
  .zz-title--terra  { color: var(--terracotta); }
  .zz-title--navy   { color: var(--navy-dark); }

  /* ---- Description ---- */
  .zz-desc {
    font-size: 1rem;
    color: var(--charcoal);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 767px) {
    .zz-line {
      left: 40px;
    }

    .zz-step,
    .zz-left,
    .zz-right {
      flex-direction: row !important;
    }

    .zz-spacer {
      display: none;
    }

    .zz-circle {
      width: 60px;
      height: 60px;
      flex-shrink: 0;
      margin-right: 1rem;
    }

    .zz-circle img {
      width: 44px;
      height: 44px;
    }

    .zz-content {
      margin: 0 !important;
      text-align: left !important;
    }
  }
</style>
