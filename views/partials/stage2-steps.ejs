<!-- Investigative Cycle: Test Grid -->
<section class="test-grid-section py-5">
  <div class="container">

    <!-- Group 1: Tests for the person being tested -->
    <h6 class="test-grid_group-label">Tests you'll likely have</h6>
    <div class="test-grid">

      <!-- Step 1: Screening Blood Work -->
      <a href="#day3" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--sage">
            <img src="<%= basePath %>/static/images/needle_4_144w.png" alt="Blood work icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--green">Cycle day 3</span>
            <h5 class="test-card_title test-card_title--green">Screening blood work + hormone panel</h5>
            <p class="test-card_desc">Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.
            </p>
          </div>
        </div>
      </a>

      <!-- Step 2: Baseline Ultrasound -->
      <a href="#day3" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--orange">
            <img src="<%= basePath %>/static/images/ultrasound_144w.png" alt="Ultrasound icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--orange">Cycle day 3</span>
            <h5 class="test-card_title test-card_title--orange">Baseline ultrasound</h5>
            <p class="test-card_desc">Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.
            </p>
          </div>
        </div>
      </a>

      <!-- Step 3: Sono -->
      <a href="#sono" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--navy">
            <img src="<%= basePath %>/static/images/doctor_144w.png" alt="Sono icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--navy">Cycle day 5 to 11</span>
            <h5 class="test-card_title test-card_title--navy">Sono (Sonohysterogram)</h5>
            <p class="test-card_desc">Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.
            </p>
          </div>
        </div>
      </a>

      <!-- Step 4: Cycle Monitoring -->
      <a href="#cycle-monitoring" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--orange">
            <img src="<%= basePath %>/static/images/ultrasound_144w.png" alt="Cycle monitoring icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--orange">Cycle day 10 to 18</span>
            <h5 class="test-card_title test-card_title--orange">Cycle monitoring</h5>
            <p class="test-card_desc">Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.
            </p>
          </div>
        </div>
      </a>

      <!-- Step 5: Progesterone -->
      <a href="#progesterone" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--green">
            <img src="<%= basePath %>/static/images/needle_4_144w.png" alt="Progesterone icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--green">Around cycle day 20</span>
            <h5 class="test-card_title test-card_title--green">P4 / Progesterone</h5>
            <p class="test-card_desc">Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.
            </p>
          </div>
        </div>
      </a>

      <!-- Step 6: Beta HCG -->
      <a href="#beta-hcg" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--green">
            <img src="<%= basePath %>/static/images/needle_4_144w.png" alt="Beta HCG icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--green test-card_tag--optional">Around cycle day 28 (Optional)</span>
            <h5 class="test-card_title test-card_title--green">Beta HCG / Pregnancy test</h5>
            <p class="test-card_desc">Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.
            </p>
          </div>
        </div>
      </a>

      <!-- Step 7: AMH + Vitamin D -->
      <a href="#anytime-tests" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--green">
            <img src="<%= basePath %>/static/images/needle_4_144w.png" alt="AMH and Vitamin D icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--green">Any day</span>
            <h5 class="test-card_title test-card_title--green">AMH + Vitamin D</h5>
            <p class="test-card_desc">Not covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.<br>
              Around $105 (AMH) + $75 (Vitamin D).</p>
          </div>
        </div>
      </a>

      <!-- Step 8: Review Appointment -->
      <a href="#review" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--navy">
            <img src="<%= basePath %>/static/images/doctor_144w.png" alt="Review appointment icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--navy">After all tests are complete</span>
            <h5 class="test-card_title test-card_title--navy">Review appointment</h5>
            <p class="test-card_desc">Covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.
            </p>
          </div>
        </div>
      </a>

    </div>

    <!-- Group 2: Tests for male partner (if applicable) -->
    <h6 class="test-grid_group-label">For your male partner (if applicable)</h6>
    <div class="test-grid test-grid--two">

      <!-- Step 9: Semen Analysis -->
      <a href="#anytime-tests" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--charcoal">
            <img src="<%= basePath %>/static/images/analysis_144w.png" alt="Semen analysis icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--charcoal">By appointment</span>
            <h5 class="test-card_title test-card_title--charcoal">Semen analysis</h5>
            <p class="test-card_desc">Not covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.<br>
              Around $160.</p>
          </div>
        </div>
      </a>

      <!-- Step 10: Vitamin D (male) -->
      <a href="#anytime-tests" class="test-card-link">
        <div class="test-card">
          <div class="test-card_circle test-card_circle--green">
            <img src="<%= basePath %>/static/images/needle_4_144w.png" alt="Vitamin D icon">
          </div>
          <div class="test-card__content">
            <span class="test-card_tag test-card_tag--green">Any day</span>
            <h5 class="test-card_title test-card_title--green">Vitamin D</h5>
            <p class="test-card_desc">Not covered by <span class="ohip-tip" data-bs-toggle="tooltip" title="OHIP (Ontario Health Insurance Plan) 
              is Ontario's publicly funded health insurance, available to eligible Ontario residents at no cost.">OHIP</span>.<br>
              Around $75.</p>
          </div>
        </div>
      </a>

    </div>

  </div>
</section>
