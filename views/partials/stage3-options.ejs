        <!-- Other services & Financial Support -->
<h6 class="test-grid_group-label">Other funded services & Financial Support</h6>
<div class="treatment-grid treatment-grid--two">

    <!-- Fertility Preservation -->
    <a href="#fertility-preservation" class="test-card-link">
        <div class="test-card test-card--optional">
            <div class="test-card_rect test-card_rect--green">
                <img src="<%= basePath %>/static/images/preserve_fertility.png" 
                    alt="Fertility preservation illustration"
                    style="object-fit: contain; padding: 8px;">
            </div>
            <div class="test-card__content">
                <h6 class="test-card_title_2 test-card_title--orange">Fertility Preservation (medical necessity)</h6>
                <p class="test-card_desc">Freezing egg or sperm samples. Not everyone will need this.
                </p>
                <p class="test-card_desc"><b class="green-text">Covered</b> by
                    <span class="ohip-tip" data-bs-toggle="tooltip" 
                        title="Ontario Fertility Program: Ontario's government-funded program that covers eligible fertility treatments.">OFP</span>. 
                    One cycle per patient.</p>
            </div>
        </div>
    </a>

    <!-- Costs & Financial Support -->
    <a href="#costs-financial-support" class="test-card-link">
        <div class="test-card">
            <div class="test-card_rect test-card_rect--green">
                <img src="<%= basePath %>/static/images/out_of_pocket.png" 
                    alt="Costs and financial support illustration">
            </div>
            <div class="test-card__content">
                <h6 class="test-card_title_2 test-card_title--green">Costs & Financial Support</h6>
                <p class="test-card_desc" >What you may still pay out of pocket, and tax credits that can help.</p>
            </div>
        </div>
    </a>

</div>



